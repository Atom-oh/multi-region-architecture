{
  "annotations": { "list": [] },
  "description": "Service dependency map and RED metrics (Rate, Error, Duration) from OTel spanmetrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row", "title": "Service Map", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "nodeGraph",
      "title": "Service Dependency Graph",
      "description": "Auto-generated from Tempo service graph. Nodes = services, edges = call relationships.",
      "datasource": { "type": "tempo", "uid": "$tempo" },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 1 },
      "targets": [
        {
          "queryType": "serviceMap",
          "serviceMapQuery": "{}"
        }
      ],
      "options": {
        "nodes": { "mainStatUnit": "ms" },
        "edges": { "mainStatUnit": "r/sec" }
      }
    },
    {
      "type": "row", "title": "RED Overview — All Services", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "type": "timeseries", "title": "Request Rate by Service",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 1, "spanNulls": true } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(service_name) (rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "legendFormat": "{{ service_name }}" }]
    },
    {
      "type": "timeseries", "title": "Error Rate by Service",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 15, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(service_name) (rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum by(service_name) (rate(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "legendFormat": "{{ service_name }}" }]
    },
    {
      "type": "timeseries", "title": "P95 Latency by Service",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms", "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by(le, service_name) (rate(otel_duration_milliseconds_bucket{span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "{{ service_name }}" }]
    },
    {
      "type": "row", "title": "Service Detail — $service", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 24 }
    },
    {
      "type": "stat", "title": "Request Rate",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "reqps", "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "Error Rate",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum(rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "P50 Latency",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 25 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.5, sum by(le) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "P95 Latency",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 25 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 5000 }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by(le) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "P99 Latency",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 25 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "ms", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2000 }, { "color": "red", "value": 10000 }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by(le) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "" }]
    },
    {
      "type": "timeseries", "title": "Latency Percentiles Over Time",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms", "custom": { "fillOpacity": 10, "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum by(le) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by(le) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by(le) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries", "title": "Throughput by Endpoint",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "fillOpacity": 15, "lineWidth": 1, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(span_name) (rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "legendFormat": "{{ span_name }}" }]
    },
    {
      "type": "table", "title": "Endpoint Performance Summary",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Error Rate" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.01 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }] },
          { "matcher": { "id": "byName", "options": "P95 (ms)" }, "properties": [{ "id": "unit", "value": "ms" }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }] },
          { "matcher": { "id": "byName", "options": "Rate (rps)" }, "properties": [{ "id": "unit", "value": "reqps" }] }
        ]
      },
      "targets": [
        { "expr": "sum by(span_name) (rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "format": "table", "instant": true, "refId": "A" },
        { "expr": "sum by(span_name) (rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\", status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum by(span_name) (rate(otel_calls_total{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m]))", "format": "table", "instant": true, "refId": "B" },
        { "expr": "histogram_quantile(0.95, sum by(le, span_name) (rate(otel_duration_milliseconds_bucket{service_name=\"$service\", span_kind=\"SPAN_KIND_SERVER\"}[5m])))", "format": "table", "instant": true, "refId": "C" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "span_name" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true }, "renameByName": { "span_name": "Endpoint", "Value #A": "Rate (rps)", "Value #B": "Error Rate", "Value #C": "P95 (ms)" } } }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["service-map", "RED", "apm", "spanmetrics"],
  "templating": {
    "list": [
      {
        "current": {},
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": {},
        "name": "tempo",
        "options": [],
        "query": "tempo",
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "name": "service",
        "query": "label_values(otel_calls_total{span_kind=\"SPAN_KIND_SERVER\"}, service_name)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Service Map & RED Metrics",
  "uid": "service-map-red",
  "version": 0,
  "refresh": "30s"
}
