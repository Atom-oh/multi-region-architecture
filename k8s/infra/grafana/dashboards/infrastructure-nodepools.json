  "links": [],
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 50,
      "options": { "content": "# Infrastructure & NodePools\nCluster capacity, Karpenter NodePool breakdown (general, critical, api-tier, worker-tier, batch-tier, memory-tier), and instance type distribution.", "mode": "markdown" },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$region" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 2 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "expr": "100 * sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[5m])) / sum(kube_node_status_allocatable{resource=\"cpu\"})", "legendFormat": "CPU %" }],
      "title": "Cluster CPU %",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$region" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent", "min": 0, "max": 100
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 2 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "expr": "100 * sum(container_memory_working_set_bytes{image!=\"\"}) / sum(kube_node_status_allocatable{resource=\"memory\"})", "legendFormat": "Memory %" }],
      "title": "Cluster Memory %",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "$region" },
