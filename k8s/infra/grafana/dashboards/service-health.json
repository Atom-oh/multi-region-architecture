{
  "annotations": { "list": [] },
  "description": "Service Health - Workload status, resource usage, and scaling across domains",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 2, "w": 24, "x": 0, "y": 0 },
      "id": 50,
      "options": { "content": "# Service Health Dashboard\nWorkload status, resource usage by domain, HPA scaling, and top consumers.", "mode": "markdown" },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 2 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=\"Running\", namespace=~\"$namespace\"})", "legendFormat": "Running" }],
      "title": "Running Pods",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 2 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_status_ready{condition=\"false\", namespace=~\"$namespace\"}) or vector(0)", "legendFormat": "Not Ready" }],
      "title": "Not Ready Pods",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 2 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[1h]))", "legendFormat": "Restarts" }],
      "title": "Restarts (1h)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 2 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"$namespace\"} != kube_horizontalpodautoscaler_status_desired_replicas{namespace=~\"$namespace\"}) or vector(0)", "legendFormat": "Scaling" }],
      "title": "HPA Scaling Active",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", image!=\"\"}[5m]))", "legendFormat": "{{namespace}}" }],
      "title": "CPU Usage by Domain",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 30, "stacking": { "mode": "normal" } },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (namespace) (container_memory_working_set_bytes{namespace=~\"$namespace\", image!=\"\"})", "legendFormat": "{{namespace}}" }],
      "title": "Memory Usage by Domain",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (namespace) (kube_pod_container_resource_requests{resource=\"cpu\", namespace=~\"$namespace\"})", "legendFormat": "{{namespace}} request", "refId": "A" },
        { "expr": "sum by (namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", image!=\"\"}[5m]))", "legendFormat": "{{namespace}} usage", "refId": "B" }
      ],
      "title": "CPU: Request vs Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (namespace) (kube_pod_container_resource_requests{resource=\"memory\", namespace=~\"$namespace\"})", "legendFormat": "{{namespace}} request", "refId": "A" },
        { "expr": "sum by (namespace) (container_memory_working_set_bytes{namespace=~\"$namespace\", image!=\"\"})", "legendFormat": "{{namespace}} usage", "refId": "B" }
      ],
      "title": "Memory: Request vs Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Deployment" }, "properties": [{ "id": "custom.width", "value": 250 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "id": 9,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Unavailable" }] },
      "targets": [{ "expr": "kube_deployment_status_replicas{namespace=~\"$namespace\"}", "format": "table", "instant": true, "legendFormat": "", "refId": "total" },
        { "expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"}", "format": "table", "instant": true, "legendFormat": "", "refId": "available" },
        { "expr": "kube_deployment_status_replicas_unavailable{namespace=~\"$namespace\"}", "format": "table", "instant": true, "legendFormat": "", "refId": "unavailable" }
      ],
      "title": "Deployment Replicas",
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "deployment" } },
        { "id": "organize", "options": { "excludeByName": { "Time 1": true, "Time 2": true, "Time 3": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "instance 1": true, "instance 2": true, "instance 3": true, "job 1": true, "job 2": true, "job 3": true, "namespace 2": true, "namespace 3": true }, "renameByName": { "deployment": "Deployment", "namespace 1": "Namespace", "Value #total": "Total", "Value #available": "Available", "Value #unavailable": "Unavailable" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m])) > 0", "legendFormat": "{{pod}}" }],
      "title": "Container Restarts (5m intervals)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 11,
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "topk(10, sum by (pod, namespace) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", image!=\"\"}[5m])))", "legendFormat": "{{namespace}}/{{pod}}" }],
      "title": "Top 10 CPU Pods",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus-east" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 12,
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "topk(10, sum by (pod, namespace) (container_memory_working_set_bytes{namespace=~\"$namespace\", image!=\"\"}))", "legendFormat": "{{namespace}}/{{pod}}" }],
      "title": "Top 10 Memory Pods",
      "type": "bargauge"
    }
  ],
  "schemaVersion": 39,
  "tags": ["service-health", "workloads", "observability"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "description": "Filter by namespace/domain",
        "hide": 0,
        "includeAll": true,
        "allValue": "core|user|fulfillment|business|platform",
        "label": "Namespace",
        "multi": true,
        "name": "namespace",
        "options": [
          { "selected": false, "text": "core", "value": "core" },
          { "selected": false, "text": "user", "value": "user" },
          { "selected": false, "text": "fulfillment", "value": "fulfillment" },
          { "selected": false, "text": "business", "value": "business" },
          { "selected": false, "text": "platform", "value": "platform" }
        ],
        "query": "core,user,fulfillment,business,platform",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Service Health",
  "uid": "service-health",
  "version": 1
}
