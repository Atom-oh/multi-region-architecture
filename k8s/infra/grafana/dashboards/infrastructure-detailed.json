{
  "annotations": { "list": [] },
  "description": "Comprehensive infrastructure monitoring — nodes, pods, resources, network, storage, and Kubernetes API health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row", "title": "Cluster Overview", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat", "title": "Total Nodes",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "count(kube_node_info)", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "Running Pods",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=\"Running\"})", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "Failed / Pending",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=~\"Failed|Pending\"}) or vector(0)", "legendFormat": "" }]
    },
    {
      "type": "stat", "title": "Restarts (1h)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } },
      "options": { "colorMode": "background_solid", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total[1h]))", "legendFormat": "" }]
    },
    {
      "type": "gauge", "title": "Cluster CPU Usage",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "max": 1, "min": 0, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\", image!=\"\"}[5m])) / sum(kube_node_status_allocatable{resource=\"cpu\"})", "legendFormat": "" }]
    },
    {
      "type": "gauge", "title": "Cluster Memory Usage",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "max": 1, "min": 0, "unit": "percentunit", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(container_memory_working_set_bytes{container!=\"\", image!=\"\"}) / sum(kube_node_status_allocatable{resource=\"memory\"})", "legendFormat": "" }]
    },
    {
      "type": "row", "title": "Node Resources", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries", "title": "CPU Usage by Node",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "fillOpacity": 15, "lineWidth": 1, "spanNulls": true } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(node) (rate(node_cpu_seconds_total{mode!=\"idle\"}[5m]))", "legendFormat": "{{ node }}" }]
    },
    {
      "type": "timeseries", "title": "Memory Usage by Node",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "fillOpacity": 15, "lineWidth": 1, "spanNulls": true } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "{{ instance }}" }]
    },
    {
      "type": "timeseries", "title": "Network Receive by Node",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(instance) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))", "legendFormat": "{{ instance }}" }]
    },
    {
      "type": "timeseries", "title": "Network Transmit by Node",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(instance) (rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[5m]))", "legendFormat": "{{ instance }}" }]
    },
    {
      "type": "timeseries", "title": "Disk I/O by Node",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps", "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "expr": "sum by(instance) (rate(node_disk_read_bytes_total[5m]))", "legendFormat": "{{ instance }} read" },
        { "expr": "sum by(instance) (rate(node_disk_written_bytes_total[5m]))", "legendFormat": "{{ instance }} write" }
      ]
    },
    {
      "type": "row", "title": "Namespace Resources", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries", "title": "CPU Usage by Namespace",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(namespace) (rate(container_cpu_usage_seconds_total{container!=\"\", image!=\"\", namespace=~\"$namespace\"}[5m]))", "legendFormat": "{{ namespace }}" }]
    },
    {
      "type": "timeseries", "title": "Memory Usage by Namespace",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "fillOpacity": 30, "lineWidth": 1, "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "sum by(namespace) (container_memory_working_set_bytes{container!=\"\", image!=\"\", namespace=~\"$namespace\"})", "legendFormat": "{{ namespace }}" }]
    },
    {
      "type": "bargauge", "title": "Top 10 CPU Pods",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-BlYlRd" }, "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "topk(10, sum by(pod, namespace) (rate(container_cpu_usage_seconds_total{container!=\"\", image!=\"\"}[5m])))", "legendFormat": "{{ namespace }}/{{ pod }}" }]
    },
    {
      "type": "bargauge", "title": "Top 10 Memory Pods",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-BlYlRd" }, "unit": "bytes", "thresholds": { "steps": [{ "color": "green", "value": null }] } } },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "topk(10, sum by(pod, namespace) (container_memory_working_set_bytes{container!=\"\", image!=\"\"}))", "legendFormat": "{{ namespace }}/{{ pod }}" }]
    },
    {
      "type": "table", "title": "Container Restarts (24h)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 39 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } },
        "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background" } }] }]
      },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [{ "expr": "sum by(namespace, pod, container) (increase(kube_pod_container_status_restarts_total[24h])) > 0", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "namespace": "Namespace", "pod": "Pod", "container": "Container", "Value": "Restarts" } } }
      ]
    },
    {
      "type": "row", "title": "Kubernetes API & Storage", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 47 }
    },
    {
      "type": "timeseries", "title": "API Server Request Rate",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 48 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps", "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by(code) (rate(apiserver_request_total[5m]))", "legendFormat": "{{ code }}" }]
    },
    {
      "type": "timeseries", "title": "API Server Latency (p99)",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 48 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "fillOpacity": 5, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "histogram_quantile(0.99, sum by(le, verb) (rate(apiserver_request_duration_seconds_bucket{verb!~\"WATCH|CONNECT\"}[5m])))", "legendFormat": "{{ verb }}" }]
    },
    {
      "type": "timeseries", "title": "Filesystem Usage by Node",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 48 },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "max": 1, "custom": { "fillOpacity": 10, "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{mountpoint=\"/\", fstype!~\"tmpfs|overlay\"})", "legendFormat": "{{ instance }}" }]
    },
    {
      "type": "row", "title": "Deployments", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 }
    },
    {
      "type": "table", "title": "Deployment Status",
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 57 },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Unavailable" }, "properties": [{ "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Namespace", "desc": false }] },
      "targets": [
        { "expr": "kube_deployment_spec_replicas{namespace=~\"$namespace\"}", "format": "table", "instant": true, "refId": "A" },
        { "expr": "kube_deployment_status_replicas_available{namespace=~\"$namespace\"}", "format": "table", "instant": true, "refId": "B" },
        { "expr": "kube_deployment_status_replicas_unavailable{namespace=~\"$namespace\"}", "format": "table", "instant": true, "refId": "C" }
      ],
      "transformations": [
        { "id": "seriesToColumns", "options": { "byField": "deployment" } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "__name__": true, "__name__ 1": true, "__name__ 2": true, "job": true, "job 1": true, "job 2": true, "instance": true, "instance 1": true, "instance 2": true, "namespace 1": true, "namespace 2": true }, "renameByName": { "namespace": "Namespace", "deployment": "Deployment", "Value #A": "Desired", "Value #B": "Available", "Value #C": "Unavailable" } } }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["infrastructure", "kubernetes", "nodes"],
  "templating": {
    "list": [
      {
        "current": {},
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": {},
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "includeAll": true,
        "multi": true,
        "name": "namespace",
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Infrastructure Detailed",
  "uid": "infra-detailed",
  "version": 0,
  "refresh": "30s"
}
