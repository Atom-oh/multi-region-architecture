# =============================================================================
# Multi-Region Shopping Mall — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These values replace <PLACEHOLDER> tokens in Terraform tfvars, K8s manifests,
# ArgoCD appsets, and build scripts throughout the repository.
# =============================================================================

# ---------------------------------------------------------------------------
# AWS Account
# ---------------------------------------------------------------------------
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Networking (ap-northeast-2)
# ---------------------------------------------------------------------------
VPC_ID_AP_NORTHEAST_2=vpc-0xxxxxxxxxxxxxxxxx
PUBLIC_SUBNET_AZ_A=subnet-0xxxxxxxxxxxxxxxxx
PUBLIC_SUBNET_AZ_C=subnet-0xxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Security Groups (ap-northeast-2)
# ---------------------------------------------------------------------------
# SG restricted to CloudFront managed prefix list (for public-facing NLBs)
CLOUDFRONT_SG_ID=sg-0xxxxxxxxxxxxxxxxx
# SG for internal observability NLBs (ClickHouse, Tempo, Prometheus)
INTERNAL_OBS_NLB_SG_ID=sg-0xxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# DNS / Route53
# ---------------------------------------------------------------------------
ROUTE53_ZONE_ID=Z0XXXXXXXXXXXXXXXXXX
# NLB hosted zone ID (region-specific, e.g. ZIBE1TIR4HY56 for ap-northeast-2)
NLB_HOSTED_ZONE_ID=ZXXXXXXXXXXXXXXX

# ---------------------------------------------------------------------------
# ACM Certificates
# ---------------------------------------------------------------------------
# CloudFront certificate (must be in us-east-1)
ACM_CERTIFICATE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# NLB DNS Names (ap-northeast-2, created by AWS LB Controller)
# ---------------------------------------------------------------------------
GRAFANA_NLB_DNS=k8s-xxxxxxx-xxxxxxx-xxxxxxxxxx-xxxxxxxxxxxxxxxx.elb.ap-northeast-2.amazonaws.com
ARGOCD_NLB_DNS=k8s-xxxxxxx-xxxxxxx-xxxxxxxxxx-xxxxxxxxxxxxxxxx.elb.ap-northeast-2.amazonaws.com
PROMETHEUS_NLB_DNS=k8s-xxxxxxx-xxxxxxx-xxxxxxxxxx-xxxxxxxxxxxxxxxx.elb.ap-northeast-2.amazonaws.com
TEMPO_NLB_DNS=k8s-xxxxxxx-xxxxxxx-xxxxxxxxxx-xxxxxxxxxxxxxxxx.elb.ap-northeast-2.amazonaws.com
CLICKHOUSE_NLB_DNS=k8s-xxxxxxx-xxxxxxx-xxxxxxxxxx-xxxxxxxxxxxxxxxx.elb.ap-northeast-2.amazonaws.com

# ---------------------------------------------------------------------------
# NLB Target Groups (ap-northeast-2, hash suffix from AWS)
# ---------------------------------------------------------------------------
TG_HASH_AZ_A=xxxxxxxxxxxxxxxx
TG_HASH_AZ_C=xxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# GitHub
# ---------------------------------------------------------------------------
GITHUB_ORG=your-github-org

# GitHub Actions Runner Controller (ARC) — App credentials
YOUR_GITHUB_APP_ID=
YOUR_GITHUB_APP_INSTALLATION_ID=
YOUR_GITHUB_APP_PRIVATE_KEY=

# ---------------------------------------------------------------------------
# Database Passwords
# ---------------------------------------------------------------------------
# Aurora / DocumentDB master password
YOUR_PASSWORD=

# ---------------------------------------------------------------------------
# OpenSearch
# ---------------------------------------------------------------------------
OPENSEARCH_PASS=
